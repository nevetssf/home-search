# Copy to ops/restic.env (gitignored) and fill in. Sourced by ops/backup.sh.

# What to back up (inside the Docker named volume on boulder-server).
# If the app runs in Docker, point these at the host mount of home-search-data,
# e.g. /var/lib/docker/volumes/home-search_home-search-data/_data/...
DB_PATH=/srv/home-search/data/home_search.db
MEDIA_PATH=/srv/home-search/data/media

# restic encryption password (same for both repos so snapshots interoperate).
RESTIC_PASSWORD=change-me-long-random

# restic repositories — SFTP to each Synology (over Tailscale for SF).
# Set up key-based SSH to the Synology rsync/SFTP user first.
BOULDER_REPO=sftp:backup@boulder-synology:/volume1/restic/home-search
SF_REPO=sftp:backup@sf-synology:/volume1/restic/home-search
