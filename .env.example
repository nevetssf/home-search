# ── home-search environment ───────────────────────────────────────────────
# Copy to .env (repo root, read by docker-compose) and/or backend/.env (read by
# pydantic-settings during local dev). All config is env-driven — no hardcoded
# paths/hosts (see PLAN.md §11 portability).

# ── Database ───────────────────────────────────────────────────────────────
# SQLite now; swap to postgresql://user:pass@host/db to move to Postgres.
DATABASE_URL=sqlite:////app/data/home_search.db

# ── Auth (JWT) ─────────────────────────────────────────────────────────────
# Generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# ── Media storage abstraction ──────────────────────────────────────────────
# local | s3   (services/storage.py)
STORAGE_BACKEND=local
MEDIA_ROOT=/app/data/media
# S3 (only when STORAGE_BACKEND=s3; any S3-compatible endpoint)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Zillow ingestion (RapidAPI zillow-com1) ────────────────────────────────
RAPIDAPI_KEY=
RAPIDAPI_ZILLOW_HOST=zillow-com1.p.rapidapi.com

# ── Realtor.com ingestion (HomeHarvest, no API key required) ───────────────
REALTOR_ENABLED=true
# Optional radius (miles) to expand an address search; 0 = exact location only.
REALTOR_DEFAULT_RADIUS=0

# ── Google Maps Platform (server-side only) ────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Scheduled status refresh ───────────────────────────────────────────────
STATUS_REFRESH_ENABLED=true
# Cron-ish: day-of-week (mon-sun / *) + hour. Default: weekly Monday 04:00.
STATUS_REFRESH_DAY_OF_WEEK=mon
STATUS_REFRESH_HOUR=4

# ── CORS (frontend origins) ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
