# Frontend build-time config (Vite reads VITE_*).
# In dev, /api is proxied to the backend; set this only for prod single-origin
# deploys where the browser must reach the backend directly.
VITE_API_URL=

# Browser Maps JavaScript API key (referrer-restricted) — DIFFERENT from the
# server-side GOOGLE_MAPS_API_KEY used for Places/Distance Matrix. Without it
# the Map view degrades to a coordinate list.
VITE_GOOGLE_MAPS_API_KEY=
